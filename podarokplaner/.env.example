BOT_TOKEN=your_bot_token_from_botfather
# Username бота без @ — нужен для ссылок-приглашений (например podarok_bot)
BOT_USERNAME=your_bot_username
WEBHOOK_URL=https://your-app.vercel.app
WEBAPP_URL=https://your-app.vercel.app
PORT=3000
PREMIUM_STARS=500
DEV_MODE=false

# База данных Turso (обязательно для Vercel)
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your_turso_token

# Секрет для cron-напоминаний (придумайте любую длинную строку)
CRON_SECRET=your_random_secret_string

# Donatty — ссылка на вашу страницу доната (https://donatty.com/creator_bots)
DONATTY_PAGE_URL=https://donatty.com/your-page
