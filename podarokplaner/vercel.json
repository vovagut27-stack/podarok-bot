{
  "version": 2,
  "buildCommand": "npm run vercel-build",
  "outputDirectory": "webapp/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/webhook", "destination": "/api" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 30
    },
    "api/cron.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "0 6 * * *"
    }
  ]
}
